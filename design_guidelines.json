  "libraries": {
    "recommended": [
      "framer-motion",
      "lucide-react",
      "clsx",
      "tailwind-merge",
      "recharts",
      "date-fns",
      "@radix-ui/react-slot"
    ],
    "installation_commands": [
      "npm install framer-motion lucide-react clsx tailwind-merge recharts date-fns",
      "npm install class-variance-authority @radix-ui/react-slot"
    ]
  },
  "instructions_to_main_agent": [
    "1. THEME SETUP: Update `tailwind.config.js` with the provided color palette. Ensure 'darkMode' is set to 'class'.",
    "2. FONT SETUP: Add 'Chivo' and 'Manrope' via Google Fonts in `index.html` or `index.css`.",
    "3. COMPONENT STYLE: When using Shadcn, override default rounded-xl with rounded-lg. Use border-slate-800 for dark mode borders.",
    "4. LAYOUT: For the landing page, use the 'Bento' grid strategy. For dashboards, use dense grids.",
    "5. CRITICAL: Do not use generic gradients. Use the specific 'hero_glow' provided in colors.gradients.",
    "6. IMAGES: Use the provided Unsplash URLs for placeholders. Do not leave empty boxes.",
    "7. DATA-TESTID: Add data-testid to all interactive elements (buttons, inputs, links)."
  ],
  "universal_guidelines": [
    "Avoid generic 'AI slop' designs.",
    "Do not center align the app container.",
    "Use glass-morphism with backdrop filters (12-24px blur).",
    "Every interaction needs micro-animations (hover, press).",
    "Use 2-3x more spacing than typical designs.",
    "Use 'sonner' for toasts.",
    "Components MUST use named exports."
  ]
}