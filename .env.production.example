# ═══════════════════════════════════════════════════════════════
# LOBBI Production Environment Variables
# Copy this file to .env.production and fill in real values
# ═══════════════════════════════════════════════════════════════

# Domain
DOMAIN=lobbi.in
EMAIL=admin@lobbi.in

# Database (internal Docker network — no changes needed)
DB_NAME=lobbi_db

# Security — CHANGE THESE! Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
CHAT_ENCRYPTION_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32

# MQTT (IoT) — optional, leave blank to use default public broker
MQTT_BROKER=broker.emqx.io
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=

# Razorpay — for payment processing
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# S3 Storage — optional, uploads fall back to local volume
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
AWS_REGION=ap-south-1

# Email (SMTP) — optional
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@lobbi.in

# Push Notifications — optional
PUSH_ENABLED=false
